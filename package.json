{
  "name": "nestjs-telemetry",
  "version": "1.0.2",
  "description": "NEST.JS Module for telemetry. Supported: Jaeger.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist && rimraf package-lock.json && rimraf node_modules && npm i",
    "build": "rimraf dist && tsc -p tsconfig.build.json"
  },
  "keywords": [
    "nestjs",
    "telemetry",
    "typescript"
  ],
  "author": "DevTriangle",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.59.0",
    "@opentelemetry/propagator-jaeger": "^2.6.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": "*",
    "@nestjs/core": "*",
    "rxjs": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DevTriangle/nestjs-telemetry.git"
  }
}
